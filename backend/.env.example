# 复制为同目录下的 .env 后修改。勿把含密码的 .env 提交到 Git。

# ─── 数据库（必填）────────────────────────────────────────────
# 本地 Docker（backend 目录执行 docker compose up -d 后）：
DATABASE_URL=postgresql://cardnote:cardnote_local_test@127.0.0.1:5433/cardnote
# 服务端会在连接串上自动附加 statement_timeout=30s（毫秒 30000），无需在 SQL 里 SET；若 URL 已含 statement_timeout 则不改。
# 本机无 SSL 时务必关闭（Docker / 本地 pg 常用）
PG_SSL=false

# 云端 PostgreSQL（腾讯云等）示例：一般可删掉 PG_SSL 行，由客户端使用 sslmode
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# 首次建表（空库，在 backend 目录）：
#   · 有 psql：  psql "$DATABASE_URL" -f scripts/schema.sql
#   · Docker：  docker compose exec -T postgres psql -U cardnote -d cardnote -v ON_ERROR_STOP=1 < scripts/schema.sql
#   · 无 psql：  把 scripts/schema.sql 在控制台/SQL 窗口执行一次
# 已有库缺 hint / 星标 / 回收站表：npm run db:migrate
#
# 不必跑 npm run migrate（migrate-json-to-pg）：仅「旧 JSON/COS → PG」用；不迁旧数据可跳过。
# 表齐 + DATABASE_URL 可连，之后新建/编辑即写入 PG。

# ─── 服务 ────────────────────────────────────────────────────
PORT=8787

# 启用登录门闩 + 首个管理员（生产必配）
# JWT_SECRET=至少32字节的随机串
# ADMIN_PASSWORD=首次启动时在空库创建管理员的密码

# 可选：静态 API Token（旧版脚本）
# API_TOKEN=

# 「问 AI」笔记助手（Google Gemini，仅服务端；登录用户可调 https://ai.google.dev/ 申请 Key）
# GEMINI_API_KEY=
# 可选：只填模型 ID（小写、短横线），不要加 models/ 前缀，不要粘贴 Vertex 全路径或中文名
# 例：gemini-2.5-flash、gemini-2.5-flash-lite、gemini-2.0-flash
# 默认 gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# 「问 AI」每月次数（自然月 Asia/Shanghai；admin 不计次；每次延伸/快捷/对话计 1 次）
# AI_USER_NOTE_ASSIST_MONTHLY=50
# AI_SUBSCRIBER_NOTE_ASSIST_MONTHLY=800

# 异步注销队列：轮询间隔（毫秒，默认 60000）；ACCOUNT_DELETION_WORKER=0 可禁用后台清理任务
# ACCOUNT_DELETION_POLL_MS=60000
# ACCOUNT_DELETION_WORKER=

# ─── CORS(生产跨域必配)──────────────────────────────────────
# 配置 CORS_ORIGIN 为你的站点域名,否则 origin 为 false(不允许跨域)。
# 多个前端源用英文逗号分隔,例如:
# CORS_ORIGIN=https://notes.example.com,https://www.example.com
# CORS_ORIGIN=
# 预检 OPTIONS 缓存秒数（默认 86400；减小可更快生效 CORS 变更）
# CORS_MAX_AGE=86400

# 反向代理后限流 / 登录按真实 IP：置 1
# TRUST_PROXY=1

# ─── 登录 Cookie（httpOnly JWT，默认开启）──────────────────────
# 设为 false 则登录不再下发 Cookie（仅 JSON 内 token，不推荐）
# AUTH_HTTPONLY_COOKIE=true
# 前后端不同子域时设置父域，如 .example.com
# AUTH_COOKIE_DOMAIN=
# 跨站 API（如 notes.example.com → api.example.com）须 none，且须 HTTPS + COOKIE_SECURE
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=true

# ─── 邮箱验证码（生产必配其一）──────────────────────────────────
# 未配置时：开发环境验证码会打在服务端日志；生产环境无法发信。
#
# 【推荐】Resend HTTP API（HTTPS，Railway Free/Hobby 禁用出站 SMTP 时须用此方式）
# RESEND_API_KEY=re_xxxxxxxx
# SMTP_FROM="卡片笔记" <noreply@cardnote.io>
#
# 【备选】传统 SMTP（自建邮局、部分云主机；Railway 非 Pro 计划出站 SMTP 会被禁用）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="卡片笔记" <noreply@example.com>
#
# Resend 若走 SMTP（仅当主机允许出站 465/587）：与上二选一，勿与 RESEND_API_KEY 混用优先权——
# 配置了 RESEND_API_KEY 时服务端会走 API，不再连 smtp.resend.com。

# ─── 腾讯云 COS（附件 / 头像 / 可选笔记 JSON）────────────────────
# 四项齐全则走 COS；否则附件落本地 public/uploads。
# COS_SECRET_ID=
# COS_SECRET_KEY=
# 例：新加坡桶 cardnote-1310791405，地域 ap-singapore
# COS_BUCKET=cardnote-1310791405
# COS_REGION=ap-singapore
#
# 默认走地域域名 https://{bucket}.cos.{region}.myqcloud.com/...
# 全球加速默认关闭；勿设 COS_USE_ACCELERATE，并在控制台「存储桶 → 全球加速」关闭。
# 若仍要用加速域名：COS_USE_ACCELERATE=1（须控制台已开启全球加速）
#
# 对象键前缀（与控制台桶内目录一致；旧桶仍用 cardnote/media 可设 COS_MEDIA_PREFIX=cardnote/media）
# COS_MEDIA_PREFIX=media
# COS_AVATAR_PREFIX=avatars
#
# 对外 URL 与默认桶域名不一致时（自定义域/CDN）：
# COS_PUBLIC_BASE=https://cardnote-1310791405.cos.ap-singapore.myqcloud.com
#
# 读预签名有效期（秒，默认 900）
# COS_READ_SIGN_EXPIRES_SEC=900
#
# CDN Token 鉴权（腾讯云 Type D；开启后 /api/upload/cos-read 优先返回 CDN 鉴权 URL）
# 需先把 COS_PUBLIC_BASE 设为你的 CDN 访问域名（例如 https://attachment.example.com）
# CDN_TOKEN_AUTH_ENABLED=true
# 主密钥（与 CDN 控制台「主 key」一致）
# CDN_TOKEN_AUTH_PRIMARY_KEY=
# 与控制台「鉴权 URL 有效时长」对齐的提示秒数（仅用于 API 返回 expiresIn；Type D 实际过期以控制台为准）
# CDN_TOKEN_AUTH_EXPIRES_SEC=900
# 控制台 Type D 常见：签名参数 sign、时间参数 t
# CDN_TOKEN_AUTH_SECRET_PARAM=sign
# CDN_TOKEN_AUTH_TIME_PARAM=t
# Type D 的 t 为十进制 Unix 秒（签发时刻）；非腾讯云场景才用十六进制
# CDN_TOKEN_AUTH_TIME_HEX=false

# ─── 附件月额度（按 role；admin 不限月额度）──────────────────────
# 普通用户 user：默认每月总上传 1 GiB。二选一覆盖。
# USER_MEDIA_MONTHLY_MAX_GB=1
# USER_MEDIA_MONTHLY_MAX_BYTES=1073741824
#
# 订阅用户 subscriber：默认每月总上传 10 GiB。二选一覆盖。
# SUBSCRIBER_MEDIA_MONTHLY_MAX_GB=10
# SUBSCRIBER_MEDIA_MONTHLY_MAX_BYTES=10737418240

# ─── 部署启动链（Docker CMD = backend/scripts/deploy-start.mjs；或 npm run start:deploy）──
# 生产环境默认不跑启动脚本（迁移/补全），只启动 API。
# 如确需在部署时执行脚本，先显式开启：
# ALLOW_STARTUP_SCRIPTS_ON_DEPLOY=1
# 之后再按需打开具体脚本开关（均默认关闭）：
# RUN_V2_MIGRATE_ON_DEPLOY=1                 # 自动执行 scripts/migrate-to-v2.js
# RUN_MEDIA_METADATA_BACKFILL_ON_DEPLOY=1    # 自动执行媒体元数据补全（失败不阻断 API）
#
# 媒体补全（缩略图 + sizeBytes，见 scripts/backfill-video-thumbnails.mjs）默认不在启动时跑，避免耗时长导致健康检查失败、整站连不上后端。
# 补全成功后写入 cardnote_deploy_hooks.media_metadata_backfill_v1（并删除旧版 video_thumb_backfill_v1）。
# SKIP_VIDEO_THUMB_BACKFILL_ON_DEPLOY=1       # 永不跑补全（沿用旧名）
# FORCE_VIDEO_THUMB_BACKFILL_ON_DEPLOY=1     # 与下项等价：清除标记后重跑
# FORCE_MEDIA_METADATA_BACKFILL_ON_DEPLOY=1   # 清除标记后重跑（语义更清晰）
