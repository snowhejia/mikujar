{
  "name": "notes-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/postbuild-cap.mjs",
    "preview": "vite preview",
    "export:collections": "tsx scripts/export-collections.ts",
    "server": "npm run start --prefix server",
    "server:dev": "npm run dev --prefix server",
    "server:db:up": "npm run db:up --prefix server",
    "server:db:test": "npm run db:test --prefix server",
    "build:deploy": "npm run build && npm run export:collections && node scripts/copy-dist-to-server.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build && node scripts/apply-dmg-finder-icon.mjs",
    "ios:xcode": "tauri ios dev -o --no-dev-server-wait",
    "ios:build": "tauri ios build",
    "dmg:icon": "node scripts/apply-dmg-finder-icon.mjs",
    "icons:from-favicon": "bash scripts/export-app-icon-from-favicon.sh",
    "cap:sync": "npm run build",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:run:ios": "npx cap run ios",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tiptap/extension-highlight": "^3.22.1",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.10"
  }
}
