{
  "name": "cardnote-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:deploy": "node scripts/deploy-start.mjs",
    "dev": "node --watch src/index.js",
    "import-users": "node scripts/import-users-json-to-pg.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:test": "node scripts/pg-connection-test.js",
    "db:apply-schema": "psql $DATABASE_URL -f scripts/schema.sql",
    "db:migrate-to-v2": "node scripts/migrate-to-v2.js",
    "db:migrate-to-v2:dry": "node scripts/migrate-to-v2.js --dry-run",
    "db:sync-to": "bash scripts/sync-db-to-url.sh"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "music-metadata": "^11.12.3",
    "nodemailer": "^6.9.16",
    "pdfjs-dist": "^5.6.205",
    "pg": "^8.20.0",
    "sharp": "^0.33.5"
  }
}
