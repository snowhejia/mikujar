{
  "name": "mikujar-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "migrate": "node scripts/migrate-json-to-pg.js",
    "migrate:cos": "node scripts/migrate-json-to-pg.js --from-cos",
    "import-users": "node scripts/import-users-json-to-pg.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:test": "node scripts/pg-connection-test.js",
    "db:migrate": "node scripts/pg-migrate-incremental.js",
    "backfill:video-thumbs": "node scripts/backfill-video-thumbnails.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^16.6.1",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "music-metadata": "^11.12.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.20.0",
    "sharp": "^0.33.5"
  }
}
