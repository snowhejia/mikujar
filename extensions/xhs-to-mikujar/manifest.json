{
  "manifest_version": 3,
  "name": "未来罐 · 小红书摘录",
  "version": "1.0.3",
  "description": "在小红书笔记页一键保存标题、正文与图片到 mikujar 后端",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": [
    "https://www.xiaohongshu.com/*",
    "https://*.xiaohongshu.com/*",
    "https://*.xhscdn.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_title": "保存当前笔记到未来罐",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*",
        "https://*.xiaohongshu.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
